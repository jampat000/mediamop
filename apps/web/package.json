{
  "name": "mediamop-web",
  "private": true,
  "version": "1.0.12",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:stop-api && npm run dev:stop-web && node ./scripts/run-dev-stack.mjs",
    "dev:stop-api": "node ../../scripts/stop-dev-api-port.mjs",
    "dev:stop-web": "node ../../scripts/stop-dev-web-port.mjs",
    "dev:fresh": "npm run dev",
    "dev:quick": "node ./scripts/run-dev-stack.mjs",
    "dev:web": "node ./node_modules/vite/bin/vite.js",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "ci": "npm run build && npm run test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.7.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
