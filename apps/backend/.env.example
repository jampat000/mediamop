# MediaMop backend (apps/backend) — copy this file to ``.env`` in the same directory
# (``apps/backend/.env``). It is loaded automatically on API startup and when running Alembic.
# Never commit real ``.env`` files.
# See ADR-0002 (database) and ADR-0003 (auth).
#
# Product-owned data root (not an implicit “use the Git checkout” path; not cwd). Unset defaults:
#   Windows: %LOCALAPPDATA%\MediaMop
#   Linux/macOS: $XDG_DATA_HOME/mediamop or ~/.local/share/mediamop
# Future logs/cache/files should live under this tree.
# MEDIAMOP_HOME=C:\ProgramData\MediaMop

# development | production (``production`` defaults SESSION_COOKIE_SECURE unless overridden)
MEDIAMOP_ENV=development

# SQLite file (optional). Relative paths are resolved under MEDIAMOP_HOME. Default: data/mediamop.sqlite3
# MEDIAMOP_DB_PATH=data/mediamop.sqlite3

# Optional directory overrides (relative segments allowed under MEDIAMOP_HOME)
# MEDIAMOP_BACKUP_DIR=backups
# MEDIAMOP_LOG_DIR=logs
# MEDIAMOP_TEMP_DIR=temp

MEDIAMOP_LOG_LEVEL=INFO

# CORS for FastAPI. When set, also used for trusted Origin/Referer on POST /api/v1/auth/*
# unless MEDIAMOP_TRUSTED_BROWSER_ORIGINS overrides that list.
# MEDIAMOP_CORS_ORIGINS=http://127.0.0.1:8782
# MEDIAMOP_TRUSTED_BROWSER_ORIGINS=

# Phase 6 — in-process rate limits (per worker, per peer IP; see ADR-0003)
# MEDIAMOP_AUTH_LOGIN_RATE_MAX_ATTEMPTS=30
# MEDIAMOP_AUTH_LOGIN_RATE_WINDOW_SECONDS=60
# MEDIAMOP_BOOTSTRAP_RATE_MAX_ATTEMPTS=10
# MEDIAMOP_BOOTSTRAP_RATE_WINDOW_SECONDS=3600

# HSTS: only when this app is always reached over HTTPS (defaults off)
# MEDIAMOP_SECURITY_ENABLE_HSTS=0

# Required for GET /api/v1/auth/csrf and signed CSRF tokens (login/logout)
# MEDIAMOP_SESSION_SECRET=replace-with-long-random-value

# Optional session cookie (defaults shown)
# MEDIAMOP_SESSION_COOKIE_NAME=mediamop_session
# MEDIAMOP_SESSION_COOKIE_SECURE=0
# MEDIAMOP_SESSION_COOKIE_SAMESITE=lax
# MEDIAMOP_SESSION_IDLE_MINUTES=720
# MEDIAMOP_SESSION_ABSOLUTE_DAYS=14

# Optional: standalone Fetcher app base URL (http/https) for read-only GET …/healthz from the dashboard API.
# MEDIAMOP_FETCHER_BASE_URL=http://127.0.0.1:8000

# Refiner — failed import cleanup toggles (default off; Radarr vs Sonarr separated). Truthy: 1/true/yes/on.
# MEDIAMOP_REFINER_RADARR_CLEANUP_QUALITY=0
# MEDIAMOP_REFINER_RADARR_CLEANUP_UNMATCHED=0
# MEDIAMOP_REFINER_RADARR_CLEANUP_CORRUPT=0
# MEDIAMOP_REFINER_RADARR_CLEANUP_DOWNLOAD_FAILED=0
# MEDIAMOP_REFINER_RADARR_CLEANUP_IMPORT_FAILED=0
# MEDIAMOP_REFINER_SONARR_CLEANUP_QUALITY=0
# MEDIAMOP_REFINER_SONARR_CLEANUP_UNMATCHED=0
# MEDIAMOP_REFINER_SONARR_CLEANUP_CORRUPT=0
# MEDIAMOP_REFINER_SONARR_CLEANUP_DOWNLOAD_FAILED=0
# MEDIAMOP_REFINER_SONARR_CLEANUP_IMPORT_FAILED=0
