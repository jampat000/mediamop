# MediaMop backend (apps/backend) — copy this file to ``.env`` in the same directory
# (``apps/backend/.env``). It is loaded automatically on API startup and when running Alembic.
# Never commit real ``.env`` files.
# See ADR-0002 (database) and ADR-0003 (auth).
#
# Product-owned data root (not an implicit “use the Git checkout” path; not cwd). Unset defaults:
#   Windows: %LOCALAPPDATA%\MediaMop
#   Linux/macOS: $XDG_DATA_HOME/mediamop or ~/.local/share/mediamop
# Future logs/cache/files should live under this tree.
# MEDIAMOP_HOME=C:\ProgramData\MediaMop

# development | production (``production`` defaults SESSION_COOKIE_SECURE unless overridden)
MEDIAMOP_ENV=development

# SQLite file (optional). Relative paths are resolved under MEDIAMOP_HOME. Default: data/mediamop.sqlite3
# MEDIAMOP_DB_PATH=data/mediamop.sqlite3

# Optional directory overrides (relative segments allowed under MEDIAMOP_HOME)
# MEDIAMOP_BACKUP_DIR=backups
# MEDIAMOP_LOG_DIR=logs
# MEDIAMOP_TEMP_DIR=temp

MEDIAMOP_LOG_LEVEL=INFO

# CORS for FastAPI. When set, also used for trusted Origin/Referer on POST /api/v1/auth/*
# unless MEDIAMOP_TRUSTED_BROWSER_ORIGINS overrides that list.
# MEDIAMOP_CORS_ORIGINS=http://127.0.0.1:8782
# MEDIAMOP_TRUSTED_BROWSER_ORIGINS=

# Phase 6 — in-process rate limits (per worker, per peer IP; see ADR-0003)
# MEDIAMOP_AUTH_LOGIN_RATE_MAX_ATTEMPTS=30
# MEDIAMOP_AUTH_LOGIN_RATE_WINDOW_SECONDS=60
# MEDIAMOP_BOOTSTRAP_RATE_MAX_ATTEMPTS=10
# MEDIAMOP_BOOTSTRAP_RATE_WINDOW_SECONDS=3600

# HSTS: only when this app is always reached over HTTPS (defaults off)
# MEDIAMOP_SECURITY_ENABLE_HSTS=0

# Required for GET /api/v1/auth/csrf and signed CSRF tokens (login/logout)
# MEDIAMOP_SESSION_SECRET=replace-with-long-random-value

# Optional session cookie (defaults shown)
# MEDIAMOP_SESSION_COOKIE_NAME=mediamop_session
# MEDIAMOP_SESSION_COOKIE_SECURE=0
# MEDIAMOP_SESSION_COOKIE_SAMESITE=lax
# MEDIAMOP_SESSION_IDLE_MINUTES=720
# MEDIAMOP_SESSION_ABSOLUTE_DAYS=14

# Optional: standalone Fetcher app base URL (http/https) for read-only GET …/healthz from the dashboard API.
# MEDIAMOP_FETCHER_BASE_URL=http://127.0.0.1:8000

# Failed-import cleanup toggles (default off; Radarr vs Sonarr separated). Primary names:
# MEDIAMOP_FAILED_IMPORT_RADARR_CLEANUP_QUALITY=0
# MEDIAMOP_FAILED_IMPORT_RADARR_CLEANUP_UNMATCHED=0
# MEDIAMOP_FAILED_IMPORT_RADARR_CLEANUP_CORRUPT=0
# MEDIAMOP_FAILED_IMPORT_RADARR_CLEANUP_DOWNLOAD_FAILED=0
# MEDIAMOP_FAILED_IMPORT_RADARR_CLEANUP_IMPORT_FAILED=0
# MEDIAMOP_FAILED_IMPORT_SONARR_CLEANUP_QUALITY=0
# MEDIAMOP_FAILED_IMPORT_SONARR_CLEANUP_UNMATCHED=0
# MEDIAMOP_FAILED_IMPORT_SONARR_CLEANUP_CORRUPT=0
# MEDIAMOP_FAILED_IMPORT_SONARR_CLEANUP_DOWNLOAD_FAILED=0
# MEDIAMOP_FAILED_IMPORT_SONARR_CLEANUP_IMPORT_FAILED=0
# Fetcher — in-process workers for ``fetcher_jobs`` (failed-import cleanup drives; SQLite-safe range 0–8; default 1).
# MEDIAMOP_FETCHER_WORKER_COUNT=1

# Refiner — in-process workers for ``refiner_jobs`` only (Refiner-owned durable queue; default 0 = workers off).
# Integer 0–8 after clamping: 1 = one concurrent worker for this lane; 2–8 = several (SQLite still one writer — see Refiner page / GET /api/v1/refiner/runtime-settings copy).
# MEDIAMOP_REFINER_WORKER_COUNT=0
# Refiner ``refiner.file.remux_pass.v1`` uses saved Refiner path settings (GET/PUT /api/v1/refiner/path-settings), not this env.
# Legacy only (still read into MediaMopSettings; not used for remux path resolution once path settings exist).
# MEDIAMOP_REFINER_REMUX_MEDIA_ROOT=
# Pruner — in-process workers for ``pruner_jobs`` (0 = disabled). See ADR-0007.
# MEDIAMOP_PRUNER_WORKER_COUNT=0
# Pruner — periodic scan that enqueues per-(instance, scope) scheduled previews from SQLite (default on).
# Independent of ``MEDIAMOP_PRUNER_WORKER_COUNT``; turn off in tight integration tests with ``create_app``.
# MEDIAMOP_PRUNER_PREVIEW_SCHEDULE_ENQUEUE_ENABLED=1
# Wall-clock seconds between DB scans (10–300 after clamp).
# MEDIAMOP_PRUNER_PREVIEW_SCHEDULE_SCAN_INTERVAL_SECONDS=45
# Pruner — allow enqueueing ``pruner.candidate_removal.apply.v1`` (Jellyfin/Emby/Plex: library removal from a stored preview snapshot). Default off.
# MEDIAMOP_PRUNER_APPLY_ENABLED=0
# Deprecated: legacy Plex live scan-and-delete flag (ignored; Plex uses preview → apply like other providers).
# MEDIAMOP_PRUNER_PLEX_LIVE_REMOVAL_ENABLED=0
# Legacy companion field (still parsed; not used to widen apply). 1..5000
# MEDIAMOP_PRUNER_PLEX_LIVE_ABS_MAX_ITEMS=150
# Subber — in-process workers for ``subber_jobs`` (0 = disabled). See ADR-0007.
# MEDIAMOP_SUBBER_WORKER_COUNT=0

# Refiner — supplied payload evaluation (``refiner.supplied_payload_evaluation.v1`` on ``refiner_jobs``).
# Evaluates JSON you attach to the job (queue-shaped rows + optional file/title candidate); no disk sweep, no *arr calls.
# Schedule is Refiner-only (not Fetcher). Legacy ``MEDIAMOP_REFINER_LIBRARY_AUDIT_PASS_SCHEDULE_*`` is still honored if these are unset.
# MEDIAMOP_REFINER_SUPPLIED_PAYLOAD_EVALUATION_SCHEDULE_ENABLED=0
# MEDIAMOP_REFINER_SUPPLIED_PAYLOAD_EVALUATION_SCHEDULE_INTERVAL_SECONDS=3600

# Refiner — Pass 3a Movies output-folder cleanup (minimum age before deleting a per-title folder under the Movies output root after a successful Movies remux; Radarr library paths checked live). 1h..30d; default 48h.
# MEDIAMOP_REFINER_MOVIE_OUTPUT_CLEANUP_MIN_AGE_SECONDS=172800

# Refiner — Pass 3b TV output-folder cleanup (minimum age on direct-child episode media before deleting a season folder under the TV output root after a successful TV remux; Sonarr episode file paths checked live). 1h..30d; default 48h.
# MEDIAMOP_REFINER_TV_OUTPUT_CLEANUP_MIN_AGE_SECONDS=172800

# Refiner — watched-folder remux scan dispatch (``refiner.watched_folder.remux_scan_dispatch.v1``) periodic enqueue.
# Refiner-only asyncio tick (same pattern as supplied payload evaluation schedule). Not a filesystem watcher.
# Does not share interval/enable state with other Refiner families. Restart API after changes.
# MEDIAMOP_REFINER_WATCHED_FOLDER_REMUX_SCAN_DISPATCH_SCHEDULE_ENABLED=0
# MEDIAMOP_REFINER_WATCHED_FOLDER_REMUX_SCAN_DISPATCH_SCHEDULE_INTERVAL_SECONDS=3600
# Optional remux enqueue for periodic ticks only (manual UI unchanged):
# MEDIAMOP_REFINER_WATCHED_FOLDER_REMUX_SCAN_DISPATCH_PERIODIC_ENQUEUE_REMUX_JOBS=0

# Refiner — work/temp stale sweep (``refiner.work_temp_stale_sweep.v1``) periodic enqueue — **per scope** (Movies vs TV).
# Each scope has its own enable + interval dedupe row. Legacy vars apply to **both** scopes when per-scope vars are unset:
# MEDIAMOP_REFINER_WORK_TEMP_STALE_SWEEP_SCHEDULE_ENABLED=0
# MEDIAMOP_REFINER_WORK_TEMP_STALE_SWEEP_SCHEDULE_INTERVAL_SECONDS=3600
# Per-scope (preferred):
# MEDIAMOP_REFINER_WORK_TEMP_STALE_SWEEP_MOVIE_SCHEDULE_ENABLED=0
# MEDIAMOP_REFINER_WORK_TEMP_STALE_SWEEP_MOVIE_SCHEDULE_INTERVAL_SECONDS=3600
# MEDIAMOP_REFINER_WORK_TEMP_STALE_SWEEP_TV_SCHEDULE_ENABLED=0
# MEDIAMOP_REFINER_WORK_TEMP_STALE_SWEEP_TV_SCHEDULE_INTERVAL_SECONDS=3600
# Minimum age (seconds) before a Refiner temp file may be deleted — **shared** for both scopes (same temp filename rule; 60 .. 30d; default 86400).
# MEDIAMOP_REFINER_WORK_TEMP_STALE_SWEEP_MIN_STALE_AGE_SECONDS=86400

# Refiner — Pass 4 failed remux cleanup sweep (terminal ``failed`` jobs only; Movies/TV independent timers and grace).
# Periodic enqueue per scope (restart API after changing schedule vars):
# MEDIAMOP_REFINER_MOVIE_FAILURE_CLEANUP_SCHEDULE_ENABLED=0
# MEDIAMOP_REFINER_MOVIE_FAILURE_CLEANUP_SCHEDULE_INTERVAL_SECONDS=3600
# MEDIAMOP_REFINER_TV_FAILURE_CLEANUP_SCHEDULE_ENABLED=0
# MEDIAMOP_REFINER_TV_FAILURE_CLEANUP_SCHEDULE_INTERVAL_SECONDS=3600
# Grace period after a remux row enters ``failed`` (uses refiner_jobs.updated_at): clamp 300..604800, default 1800.
# MEDIAMOP_REFINER_MOVIE_FAILURE_CLEANUP_GRACE_PERIOD_SECONDS=1800
# MEDIAMOP_REFINER_TV_FAILURE_CLEANUP_GRACE_PERIOD_SECONDS=1800

# Shared *arr HTTP (neutral; Refiner candidate gate and Fetcher drives/search resolve via arr_http_*_credentials()).
# When unset, legacy MEDIAMOP_FETCHER_*_BASE_URL / *_API_KEY values are still used for the same Radarr/Sonarr instance.
# MEDIAMOP_ARR_RADARR_BASE_URL=http://127.0.0.1:7878
# MEDIAMOP_ARR_RADARR_API_KEY=
# MEDIAMOP_ARR_SONARR_BASE_URL=http://127.0.0.1:8989
# MEDIAMOP_ARR_SONARR_API_KEY=

# Fetcher — Radarr HTTP targets for the live failed-import cleanup drive (optional until workers run that job).
# MEDIAMOP_FETCHER_RADARR_BASE_URL=http://127.0.0.1:7878
# MEDIAMOP_FETCHER_RADARR_API_KEY=

# Fetcher — Sonarr HTTP targets for the live failed-import cleanup drive (optional until workers run that job).
# MEDIAMOP_FETCHER_SONARR_BASE_URL=http://127.0.0.1:8989
# MEDIAMOP_FETCHER_SONARR_API_KEY=

# Fetcher — Sonarr/Radarr missing + upgrade search (``fetcher_jobs`` + in-process Fetcher workers only).
# Four independent lanes; each has its own enqueue interval, batch limit, retry/cooldown minutes, and schedule window.
# Cooldown persistence is keyed per lane (sonarr/radarr × missing/upgrade), not globally.
# MEDIAMOP_FETCHER_SONARR_MISSING_SEARCH_ENABLED=1
# MEDIAMOP_FETCHER_SONARR_UPGRADE_SEARCH_ENABLED=1
# MEDIAMOP_FETCHER_RADARR_MISSING_SEARCH_ENABLED=1
# MEDIAMOP_FETCHER_RADARR_UPGRADE_SEARCH_ENABLED=1
# Legacy spelling (still honored if the lane-prefixed key above is unset):
# MEDIAMOP_FETCHER_SONARR_SEARCH_MISSING_ENABLED=1
# MEDIAMOP_FETCHER_SONARR_SEARCH_UPGRADE_ENABLED=1
# MEDIAMOP_FETCHER_RADARR_SEARCH_MISSING_ENABLED=1
# MEDIAMOP_FETCHER_RADARR_SEARCH_UPGRADE_ENABLED=1
# Per-lane batch + retry (optional; if unset, legacy app-wide vars below apply to both Sonarr lanes or both Radarr lanes).
# MEDIAMOP_FETCHER_SONARR_MISSING_SEARCH_MAX_ITEMS_PER_RUN=50
# MEDIAMOP_FETCHER_SONARR_MISSING_SEARCH_RETRY_DELAY_MINUTES=1440
# MEDIAMOP_FETCHER_SONARR_UPGRADE_SEARCH_MAX_ITEMS_PER_RUN=50
# MEDIAMOP_FETCHER_SONARR_UPGRADE_SEARCH_RETRY_DELAY_MINUTES=1440
# MEDIAMOP_FETCHER_RADARR_MISSING_SEARCH_MAX_ITEMS_PER_RUN=50
# MEDIAMOP_FETCHER_RADARR_MISSING_SEARCH_RETRY_DELAY_MINUTES=1440
# MEDIAMOP_FETCHER_RADARR_UPGRADE_SEARCH_MAX_ITEMS_PER_RUN=50
# MEDIAMOP_FETCHER_RADARR_UPGRADE_SEARCH_RETRY_DELAY_MINUTES=1440
# Legacy fallback when a lane-specific MAX/RETRY env is omitted:
# MEDIAMOP_FETCHER_SONARR_SEARCH_MAX_ITEMS_PER_RUN=50
# MEDIAMOP_FETCHER_RADARR_SEARCH_MAX_ITEMS_PER_RUN=50
# MEDIAMOP_FETCHER_SONARR_SEARCH_RETRY_DELAY_MINUTES=1440
# MEDIAMOP_FETCHER_RADARR_SEARCH_RETRY_DELAY_MINUTES=1440
# MEDIAMOP_FETCHER_SONARR_MISSING_SEARCH_SCHEDULE_INTERVAL_SECONDS=3600
# MEDIAMOP_FETCHER_SONARR_UPGRADE_SEARCH_SCHEDULE_INTERVAL_SECONDS=3600
# MEDIAMOP_FETCHER_RADARR_MISSING_SEARCH_SCHEDULE_INTERVAL_SECONDS=3600
# MEDIAMOP_FETCHER_RADARR_UPGRADE_SEARCH_SCHEDULE_INTERVAL_SECONDS=3600
# Per-lane schedule windows (worker enforces at run time; shared IANA timezone).
# MEDIAMOP_FETCHER_SONARR_MISSING_SEARCH_SCHEDULE_ENABLED=0
# MEDIAMOP_FETCHER_SONARR_MISSING_SEARCH_SCHEDULE_DAYS=
# MEDIAMOP_FETCHER_SONARR_MISSING_SEARCH_SCHEDULE_START=00:00
# MEDIAMOP_FETCHER_SONARR_MISSING_SEARCH_SCHEDULE_END=23:59
# MEDIAMOP_FETCHER_SONARR_UPGRADE_SEARCH_SCHEDULE_ENABLED=0
# MEDIAMOP_FETCHER_SONARR_UPGRADE_SEARCH_SCHEDULE_DAYS=
# MEDIAMOP_FETCHER_SONARR_UPGRADE_SEARCH_SCHEDULE_START=00:00
# MEDIAMOP_FETCHER_SONARR_UPGRADE_SEARCH_SCHEDULE_END=23:59
# MEDIAMOP_FETCHER_RADARR_MISSING_SEARCH_SCHEDULE_ENABLED=0
# MEDIAMOP_FETCHER_RADARR_MISSING_SEARCH_SCHEDULE_DAYS=
# MEDIAMOP_FETCHER_RADARR_MISSING_SEARCH_SCHEDULE_START=00:00
# MEDIAMOP_FETCHER_RADARR_MISSING_SEARCH_SCHEDULE_END=23:59
# MEDIAMOP_FETCHER_RADARR_UPGRADE_SEARCH_SCHEDULE_ENABLED=0
# MEDIAMOP_FETCHER_RADARR_UPGRADE_SEARCH_SCHEDULE_DAYS=
# MEDIAMOP_FETCHER_RADARR_UPGRADE_SEARCH_SCHEDULE_START=00:00
# MEDIAMOP_FETCHER_RADARR_UPGRADE_SEARCH_SCHEDULE_END=23:59
# Legacy fallback when a lane-specific schedule env is omitted (applies to both Sonarr or both Radarr lanes):
# MEDIAMOP_FETCHER_SONARR_SEARCH_SCHEDULE_ENABLED=0
# MEDIAMOP_FETCHER_SONARR_SEARCH_SCHEDULE_DAYS=
# MEDIAMOP_FETCHER_SONARR_SEARCH_SCHEDULE_START=00:00
# MEDIAMOP_FETCHER_SONARR_SEARCH_SCHEDULE_END=23:59
# MEDIAMOP_FETCHER_RADARR_SEARCH_SCHEDULE_ENABLED=0
# MEDIAMOP_FETCHER_RADARR_SEARCH_SCHEDULE_DAYS=
# MEDIAMOP_FETCHER_RADARR_SEARCH_SCHEDULE_START=00:00
# MEDIAMOP_FETCHER_RADARR_SEARCH_SCHEDULE_END=23:59
# MEDIAMOP_FETCHER_ARR_SEARCH_SCHEDULE_TIMEZONE=UTC

# Failed-import periodic enqueue for live cleanup drive jobs (default off each). Interval clamped 60s–7d (default 3600).
# MEDIAMOP_FAILED_IMPORT_RADARR_CLEANUP_DRIVE_SCHEDULE_ENABLED=0
# MEDIAMOP_FAILED_IMPORT_RADARR_CLEANUP_DRIVE_SCHEDULE_INTERVAL_SECONDS=3600
# MEDIAMOP_FAILED_IMPORT_SONARR_CLEANUP_DRIVE_SCHEDULE_ENABLED=0
# MEDIAMOP_FAILED_IMPORT_SONARR_CLEANUP_DRIVE_SCHEDULE_INTERVAL_SECONDS=3600
