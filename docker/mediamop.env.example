# Copy to `.env.mediamop` (or another path) and pass to Compose:
#   docker compose --env-file .env.mediamop -f docker-compose.mediamop.yml up
#
# Required — at least 32 random characters (used for sessions and crypto key material).
MEDIAMOP_SESSION_SECRET=replace-with-openssl-rand-hex-32-or-longer-secret

# Optional — persistent data root inside the container (SQLite, logs, …).
# MEDIAMOP_HOME=/data/mediamop

# Default image sets MEDIAMOP_SESSION_COOKIE_SECURE=false so sign-in works on http://localhost
# and plain HTTP LAN URLs. When **every** browser hits MediaMop over HTTPS (TLS at reverse proxy),
# set:
# MEDIAMOP_SESSION_COOKIE_SECURE=true
