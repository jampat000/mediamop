# Copy to `.env.mediamop` in the repo root, set MEDIAMOP_SESSION_SECRET, then:
#   docker compose --env-file .env.mediamop pull
#   docker compose --env-file .env.mediamop up -d
# (Uses compose.yaml — GHCR image, no local build.) Local build: -f docker-compose.mediamop.yml up --build
#
# Required — at least 32 random characters (used for sessions and crypto key material).
MEDIAMOP_SESSION_SECRET=replace-with-openssl-rand-hex-32-or-longer-secret

# Optional — persistent data root inside the container (SQLite, logs, …).
# MEDIAMOP_HOME=/data/mediamop

# Default image sets MEDIAMOP_SESSION_COOKIE_SECURE=false so sign-in works on http://localhost
# and plain HTTP LAN URLs. When **every** browser hits MediaMop over HTTPS (TLS at reverse proxy),
# set:
# MEDIAMOP_SESSION_COOKIE_SECURE=true

# Optional — only when using docker-compose.mediamop.ghcr.yml (override registry image / tag).
# Default in that compose file is ghcr.io/jampat000/mediamop:alpha
# MEDIAMOP_DOCKER_IMAGE=ghcr.io/your-github-user/your-repo:alpha
